class {{PascalCase}}InvalidTransitionError(ValueError):
    pass


# TEMPLATE: dentro de {{PascalCase}}Service —

def transicionar_{{snake_case}}(
    self,
    db: Session,
    *,
    empresa_id: str,
    {{snake_case}}_id: str,
    novo_status: str,
    allowed_current: set[str],
    motivo: str | None,
    actor_usuario_id: str,
    event_type: DomainEventType,
    invalid_message: str,
) -> {{PascalCase}}:
    try:
        item = self.obter_{{snake_case}}(db, empresa_id=str(empresa_id), {{snake_case}}_id={{snake_case}}_id)
        if item.status not in allowed_current:
            raise {{PascalCase}}InvalidTransitionError(invalid_message)

        now = datetime.now(timezone.utc)
        status_anterior = item.status
        item.status = novo_status
        item.updated_at = now
        self.repository.update(db, item)
        self._publish_event(
            db, item, event_type, actor_usuario_id,
            occurred_at=now, status_anterior=status_anterior, status_atual=novo_status,
        )
        db.commit()
        db.refresh(item)
        return item
    except Exception:
        db.rollback()
        raise

