from datetime import datetime, timezone
from uuid import UUID

from pydantic import BaseModel, ConfigDict, Field, field_validator, model_validator

from app.models.{{snake_case}} import {{PascalCase}}Status


def ensure_timezone_aware(value: datetime | None) -> datetime | None:
    if value is None:
        return None
    if value.tzinfo is None or value.tzinfo.utcoffset(value) is None:
        return value.replace(tzinfo=timezone.utc)
    return value.astimezone(timezone.utc)


def normalize_optional_text(value: str | None) -> str | None:
    if value is None:
        return None
    normalized = value.strip()
    return normalized or None


class {{PascalCase}}Base(BaseModel):
    nome: str = Field(max_length=255)

    # TEMPLATE: adicione outros campos aqui. Nunca inclua o campo técnico
    # gerado pelo Service (ex.: codigo_interno) — extra="forbid" abaixo
    # garante que enviá-lo é rejeitado.
    model_config = ConfigDict(populate_by_name=True, extra="forbid")

    @field_validator("nome")
    @classmethod
    def strip_text(cls, value: str) -> str:
        normalized = normalize_optional_text(value)
        if not normalized:
            raise ValueError("nome é obrigatório")
        return normalized


class {{PascalCase}}Create({{PascalCase}}Base):
    empresa_id: UUID = Field(alias="empresaId")
    status: {{PascalCase}}Status = {{PascalCase}}Status.ATIVO


class {{PascalCase}}Update(BaseModel):
    nome: str | None = Field(default=None, max_length=255)

    model_config = ConfigDict(populate_by_name=True, extra="forbid")

    @field_validator("nome")
    @classmethod
    def strip_text(cls, value: str | None) -> str | None:
        return normalize_optional_text(value)


class {{PascalCase}}Response(BaseModel):
    id: UUID
    empresa_id: UUID = Field(alias="empresaId")
    nome: str
    status: {{PascalCase}}Status
    created_at: datetime = Field(alias="createdAt")
    updated_at: datetime = Field(alias="updatedAt")

    model_config = ConfigDict(from_attributes=True, populate_by_name=True)

    @field_validator("created_at", "updated_at")
    @classmethod
    def validate_timezone(cls, value: datetime) -> datetime:
        return ensure_timezone_aware(value)
