# Backend only. Generate a strong, unique value for each deployment.
AUTH_SECRET_KEY=replace-with-a-strong-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend only. Keep this duration aligned with the backend JWT expiry.
TASKFLOWW_API_INTERNAL_URL=http://taskfloww_api:8000
TASKFLOWW_AUTH_ALLOWED_ORIGINS=http://localhost:3010
TASKFLOWW_SESSION_MAX_AGE_SECONDS=1800
