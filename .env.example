############################################
# DATABASE AND CACHE — BACKEND ONLY
############################################

# Use credentials specific to each environment. Never commit the real value.
DATABASE_URL=postgresql://usuario:senha@taskfloww_db:5432/taskfloww
REDIS_URL=redis://taskfloww_redis:6379/0

############################################
# JWT AUTHENTICATION — BACKEND ONLY
############################################

# Generate a strong, unique secret for each deployment.
AUTH_SECRET_KEY=
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

############################################
# AUTHENTICATION BFF — FRONTEND ONLY
############################################

# Internal Docker URL. This address is never exposed to the browser.
TASKFLOWW_API_INTERNAL_URL=http://taskfloww_api:8000

# Comma-separated explicit browser origins, without paths or trailing slash.
# Development/NOC example:
TASKFLOWW_AUTH_ALLOWED_ORIGINS=http://localhost:3010,http://10.153.110.10:3010

# Keep this duration aligned with the backend access-token expiry.
TASKFLOWW_SESSION_MAX_AGE_SECONDS=1800

# Company inserted server-side by the BFF during login.
AUTH_DEFAULT_EMPRESA_CODIGO=EMP-TESTCLIENT
